<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Blog</title>
</head>
<body>

    <%- include('./partials/nav') %>
    <div class="container mt-4">
        <h1><%= blog.title %></h1>
        <img src="<%= blog.coverImageURL %>" width="500vw" alt="">
        <pre class="mt-4"><%= blog.body %></p>
    </div>
    <div class="container mt-4">
        <h3>Created By:-</h3>
        <img src="<%= blog.createdBy.profileImageUrl %>" width="50px"/>
        <%= blog.createdBy.fullname %>

    </div>
    <%- include('./partials/script') %>
</body>
</html>